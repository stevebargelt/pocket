{
  "name": "pocket",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "description": "Pocket — local-first typing tutor for the MoErgo Glove 80 (v1.1: five-context corpus router — prompts, CLI, code, email, teams — + weakness engine).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,server -c cyan,green \"vite\" \"tsx watch src/server/index.ts\"",
    "build": "vite build",
    "start": "vite build && tsx src/server/index.ts",
    "serve": "tsx src/server/index.ts",
    "seed": "tsx scripts/seed-corpus.ts",
    "curate": "tsx scripts/curate-corpus.ts",
    "curate:cli": "tsx scripts/curate-cli.ts",
    "curate:code": "tsx scripts/curate-code.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^24",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
