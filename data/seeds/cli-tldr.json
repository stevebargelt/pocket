{
  "context": "cli",
  "source": "tldr-pages",
  "license": "CC-BY-4.0",
  "note": "Hand-curated seed of short, common command-line examples in the style of tldr-pages (https://github.com/tldr-pages/tldr), shipped because a raw tldr-pages checkout was not available at build time. tldr-pages is licensed CC-BY-4.0 and is attributed in CREDITS.md. Regenerate from a local clone with scripts/curate-cli.ts (point it at data/tldr-raw/). nl2bash data is deliberately NOT bundled (non-commercial license); see data/PROVENANCE.md.",
  "items": [
    "tar -czf archive.tar.gz path/to/directory",
    "tar -xzf archive.tar.gz",
    "find . -name \"*.log\" -type f",
    "find . -type f -size +10M",
    "grep -rn \"TODO\" src/",
    "grep -i \"error\" /var/log/syslog",
    "ls -lah --color=auto",
    "cp -r source/ destination/",
    "mv old_name.txt new_name.txt",
    "rm -rf build/ dist/",
    "chmod +x script.sh",
    "chmod 755 /usr/local/bin/tool",
    "chown -R user:group /var/www",
    "ps aux | grep node",
    "kill -9 $(pgrep node)",
    "df -h /",
    "du -sh ./*",
    "curl -fsSL https://example.com/install.sh | sh",
    "curl -X POST -H \"Content-Type: application/json\" -d '{}' :3000",
    "wget -O output.zip https://example.com/file.zip",
    "ssh -i ~/.ssh/id_ed25519 user@host.example.com",
    "scp file.txt user@host:/remote/path/",
    "rsync -avz --delete src/ dest/",
    "sed -i 's/foo/bar/g' file.txt",
    "awk '{print $1}' access.log",
    "sort -u names.txt | head -n 20",
    "cut -d',' -f1,3 data.csv",
    "xargs -I {} mv {} archive/ < list.txt",
    "echo $PATH | tr ':' '\\n'",
    "cat /etc/hosts | grep localhost",
    "head -n 50 large_file.log",
    "tail -f /var/log/nginx/access.log",
    "diff -u old.txt new.txt",
    "ln -s /opt/app/bin/tool /usr/local/bin/tool",
    "mkdir -p src/components/ui",
    "touch .env.local",
    "export NODE_ENV=production",
    "env | sort",
    "which python3",
    "ping -c 4 8.8.8.8"
  ]
}
